// ─────────────────────────────────────────────
// CHORD TRANSPOSITION
// ─────────────────────────────────────────────
const CHROMATIC_SHARP = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
const CHROMATIC_FLAT  = ['C','Db','D','Eb','E','F','Gb','G','Ab','A','Bb','B'];

function noteToIndex(note) {
  let idx = CHROMATIC_SHARP.indexOf(note);
  if (idx === -1) idx = CHROMATIC_FLAT.indexOf(note);
  return idx;
}

function transposeNote(note, semitones, useFlat) {
  const idx = noteToIndex(note);
  if (idx === -1) return note;
  const newIdx = ((idx + semitones) % 12 + 12) % 12;
  return useFlat ? CHROMATIC_FLAT[newIdx] : CHROMATIC_SHARP[newIdx];
}

function transposeChord(chord, semitones, useFlat) {
  // Match root note (e.g. C, C#, Db, etc.) followed by optional quality
  return chord.replace(/([A-G][b#]?)/g, (match) => transposeNote(match, semitones, useFlat));
}

const CHORD_REGEX = /\b([A-G][b#]?(?:maj|min|m|M|aug|dim|sus|add|dom)?[0-9]?(?:\/[A-G][b#]?)?)\b/g;

function transposeContent(content, semitones, useFlat) {
  if (semitones === 0 && !useFlat) return content;
  // Only transpose chords that appear in chord lines (lines that are mostly chords)
  return content.split('\n').map(line => {
    const trimmed = line.trim();
    // Skip section labels like [Intro], [Refrão], etc.
    if (trimmed.startsWith('[') && trimmed.endsWith(']')) return line;
    // Skip lines with lots of lowercase words (lyrics)
    const lowercaseRatio = (line.match(/[a-z]/g) || []).length / Math.max(line.length, 1);
    if (lowercaseRatio > 0.4) return line;
    // Transpose chord tokens
    return line.replace(CHORD_REGEX, (chord) => transposeChord(chord, semitones, useFlat));
  }).join('\n');
}

// ─────────────────────────────────────────────
// RENDER HELPERS
// ─────────────────────────────────────────────
function levelClass(level) {
  return 'badge-level-' + level.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
}

function renderContent(content) {
  return content.split('\n').map(line => {
    const trimmed = line.trim();
    if (trimmed.startsWith('[') && trimmed.endsWith(']')) {
      return `<span class="section-label">${escHtml(line)}</span>`;
    }
    const lowercaseRatio = (line.match(/[a-z]/g) || []).length / Math.max(line.length, 1);
    if (lowercaseRatio <= 0.4 && trimmed.length > 0) {
      return line.replace(CHORD_REGEX, (chord) => `<span class="chord">${escHtml(chord)}</span>`);
    }
    return escHtml(line);
  }).join('\n');
}

function escHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ─────────────────────────────────────────────
// HOME PAGE
// ─────────────────────────────────────────────
let sortKey = 'title';
let sortDir = 1;

function initGenreFilter() {
  const genres = [...new Set(SONGS.map(s => s.genre))].sort();
  const sel = document.getElementById('filter-genre');
  genres.forEach(g => {
    const opt = document.createElement('option');
    opt.value = g; opt.textContent = g;
    sel.appendChild(opt);
  });
}

function setSort(key) {
  if (sortKey === key) sortDir *= -1;
  else { sortKey = key; sortDir = 1; }
  document.querySelectorAll('.table-header span').forEach(s => s.classList.remove('sort-active'));
  const el = document.querySelector(`.table-header [data-sort="${key}"]`);
  if (el) el.classList.add('sort-active');
  renderList();
}

function renderList() {
  const query = document.getElementById('search-input').value.toLowerCase();
  const genre = document.getElementById('filter-genre').value;
  const level = document.getElementById('filter-level').value;

  let filtered = SONGS.filter(s => {
    const matchQ = !query || s.title.toLowerCase().includes(query) || s.band.toLowerCase().includes(query);
    const matchG = !genre || s.genre === genre;
    const matchL = !level || s.level === level;
    return matchQ && matchG && matchL;
  });

  filtered.sort((a, b) => {
    const va = a[sortKey] || ''; const vb = b[sortKey] || '';
    return va.localeCompare(vb, 'pt') * sortDir;
  });

  const container = document.getElementById('songs-container');

  if (filtered.length === 0) {
    container.innerHTML = '<div class="empty-state">Nenhuma música encontrada.</div>';
    return;
  }

  container.innerHTML = `
    <div class="table-header">
      <span data-sort="title" onclick="setSort('title')" class="${sortKey==='title'?'sort-active':''}">Título / Banda</span>
      <span data-sort="genre" onclick="setSort('genre')" class="${sortKey==='genre'?'sort-active':''}">Gênero</span>
      <span data-sort="level" onclick="setSort('level')" class="${sortKey==='level'?'sort-active':''}">Nível</span>
      <span></span>
    </div>
    ${filtered.map(s => `
      <div class="song-row" onclick="showSong(${s.id})">
        <div class="song-title-cell">
          <strong>${escHtml(s.title)}</strong>
          <span>${escHtml(s.band)}</span>
        </div>
        <span class="badge badge-genre">${escHtml(s.genre)}</span>
        <span class="badge ${levelClass(s.level)}">${escHtml(s.level)}</span>
        <span style="color:var(--text-dim); font-size:18px;">›</span>
      </div>
    `).join('')}
  `;
}

// ─────────────────────────────────────────────
// SONG PAGE
// ─────────────────────────────────────────────
let currentSong = null;
let transpose = 0;
let useFlat = false;
let fontSize = 15;

function showSong(id) {
  currentSong = SONGS.find(s => s.id === id);
  transpose = 0;
  useFlat = false;
  fontSize = 15;
  renderSong();
  showPage('song');
}

function renderSong() {
  if (!currentSong) return;
  const s = currentSong;
  const content = transposeContent(s.content, transpose, useFlat);
  const transLabel = transpose === 0 ? '0' : (transpose > 0 ? '+'+transpose : transpose);

  document.getElementById('song-content').innerHTML = `
    <button class="song-back" onclick="showPage('home')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      Todas as músicas
    </button>

    <div class="song-meta">
      <h1>${escHtml(s.title)}</h1>
      <div class="band">${escHtml(s.band)}</div>
      <div class="song-meta-tags">
        <span class="badge badge-genre">${escHtml(s.genre)}</span>
        <span class="badge ${levelClass(s.level)}">${escHtml(s.level)}</span>
        <span style="font-size:12px; color:var(--text-dim);">Tom: ${escHtml(s.key)}${s.capo > 0 ? ' • Capo '+s.capo : ''}</span>
      </div>
    </div>

    <div class="song-controls">
      <div class="transpose-group">
        <span>Transpor</span>
        <button class="btn-icon" onclick="changeTranspose(-1)">−</button>
        <span class="transpose-value">${transLabel}</span>
        <button class="btn-icon" onclick="changeTranspose(1)">+</button>
      </div>
      <span class="sep">|</span>
      <button class="btn-flat ${useFlat ? 'active' : ''}" onclick="toggleFlat()">♭ bemóis</button>
      <div class="font-group">
        <span>Texto</span>
        <button class="btn-icon" onclick="changeFontSize(-1)">−</button>
        <span class="transpose-value">${fontSize}</span>
        <button class="btn-icon" onclick="changeFontSize(1)">+</button>
      </div>
    </div>

    <div class="chord-sheet" id="chord-sheet-content" style="font-size:${fontSize}px">${renderContent(content)}</div>
  `;
}

function changeTranspose(delta) {
  transpose = ((transpose + delta + 12) % 12);
  if (transpose > 6) transpose -= 12;
  renderSong();
}

function toggleFlat() {
  useFlat = !useFlat;
  renderSong();
}

function changeFontSize(delta) {
  fontSize = Math.max(11, Math.min(24, fontSize + delta));
  renderSong();
}

// ─────────────────────────────────────────────
// ROUTING
// ─────────────────────────────────────────────
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  window.scrollTo(0, 0);
  if (name === 'home') renderList();
}

// INIT
initGenreFilter();
renderList();
</script>
</body>
</html>
